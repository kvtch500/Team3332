<!--
  AndroidManifest-additions.xml  (619d)
  TEAM 3332 — manifest entries the run-notification (Live Activity analog) needs.

  `android/` is gitignored (regenerated by `npx cap add android`), so the live manifest at
  android/app/src/main/AndroidManifest.xml is NOT committed. This file is the committed record of
  the edits to paste in. Re-apply after any `cap add android`.

  NOTE: the location/background-GPS permissions are documented separately in SETUP-ANDROID.md
  (Step 2). The two entries below are what the LIVE ACTIVITY notification specifically needs, on
  top of those.
-->

<!-- 1) POST_NOTIFICATIONS — Android 13+ (API 33) requires this to show ANY notification, including
     the run-stats card. Already listed in SETUP-ANDROID.md Step 2 for the background-GPS tracking
     notification; the run-stats notification rides the same grant, so no extra runtime prompt.
     Place inside <manifest>, above <application>: -->
<uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

<!-- 2) team3332:// deep-link — lets tapping the notification (and the iOS-parity team3332://run URL)
     open the app to the record screen via the existing @capacitor/app appUrlOpen handler in app.jsx.
     Add this <intent-filter> INSIDE the existing
       <activity android:name=".MainActivity" ...>
     element (alongside the LAUNCHER intent-filter Capacitor generates): -->
<intent-filter>
    <action android:name="android.intent.action.VIEW" />
    <category android:name="android.intent.category.DEFAULT" />
    <category android:name="android.intent.category.BROWSABLE" />
    <data android:scheme="team3332" android:host="run" />
</intent-filter>
